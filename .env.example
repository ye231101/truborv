# ── Local development ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=http://127.0.0.1:8000
INTERNAL_API_ORIGIN=http://127.0.0.1:8000
NEXT_PUBLIC_API_ORIGIN=http://127.0.0.1:8000

# Browser uses same-origin /api proxy (app/api/[...path]/route.ts) — do NOT set NEXT_PUBLIC_API_ORIGIN locally.

# ── Production (Vercel env vars for www.recvana.com) ───────────────────────────
# Direct browser → backend calls. Required: Vercel /api proxy times out at ~10s.
# NEXT_PUBLIC_API_ORIGIN=https://api.viewpro.com
# INTERNAL_API_ORIGIN=https://api.viewpro.com
# NEXT_PUBLIC_SERVER_URL=https://api.viewpro.com

# Optional overrides (auto-built from NEXT_PUBLIC_API_ORIGIN when unset):
# NEXT_PUBLIC_VIEWPRO_WIDGET_URL=/viewpro-widget.js?isVisible=false&apiBase=https://api.viewpro.com/api&avatarBase=https://api.viewpro.com/public/avatars/

# Optional: extra hosts for `next dev` when not on localhost (comma-separated)
# ALLOWED_DEV_ORIGINS=192.168.80.130
